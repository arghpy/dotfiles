#!/usr/bin/env bash

# Icons

WIFI_ICON="ď‡«"
ETH_ICON="ď›ż"

# Variables

NETWORKS=$(nmcli -t | grep "connected to" | awk -F ':' '{print $1}')

ETH=$(echo "$NETWORKS" | grep 'e')

WIFI=$(echo "$NETWORKS" | grep 'w')

if [[ -n $ETH ]]; then
	printf "%s" "$ETH_ICON ETH"
elif [[ -n $WIFI ]]; then
	SSID=$(nmcli -t | grep "connected to" | grep $WIFI | awk '{print $NF}')
	printf "%s %s" "$WIFI_ICON" "$SSID"
else
	printf "%s" "$WIFI_ICON"
fi
